Now we need to Integrate in our job pipeline

Now add Maven tool & CAQ stage in Job pipeline like below

pipeline {
    agent any
    tools {
        maven 'mymaven'
    }
    stages {
        stage ("Code") {
            steps {
                git 'https://github.com/pranay-devops666/dockerwebapp.git'
            }
        }
        stage ("CAQ") {
            steps {
                withSonarQubeEnv('mysonar') {
                    sh "mvn clean verify sonar:sonar -Dsonar.projectKey=MyProject"
                }
            }
        }
    }
}

